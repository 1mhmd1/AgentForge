# ── Runner ────────────────────────────────────────────────────────────

def run() -> None:
    ensure_output_dir()

    print(f"[AgentForge:{DOMAIN}] run_id={RUN_ID}")
    print(f"[AgentForge:{DOMAIN}] {INPUT_FILE_FORMAT} → {OUTPUT_FILE_FORMAT}")
    print(f"[AgentForge:{DOMAIN}] steps={len(STEPS)}")

    write_json(SCHEMA_PATH, {
        "input_schema": INPUT_SCHEMA,
        "output_schema": OUTPUT_SCHEMA,
        "column_mapping": COLUMN_MAPPING,
        "validation_rules": VALIDATION_RULES,
    })

    try:
        step_results = {}

        {% for step in steps %}
        print(f"[Step {{ loop.index }}] {{ step }}")
        step_results["step_{{ loop.index }}"] = execute_step_{{ loop.index }}()
        {% endfor %}

        records = load_data()
        input_report = validate_input(records)
        transformed = transform(records)
        output_report = validate_output(transformed)
        out_path = export_data(transformed)

        validation_report = {
            "input_validation": input_report,
            "output_validation": output_report,
            "total_records": len(records),
            "transformed": len(transformed),
            "step_results": step_results,
        }
        write_json(VALIDATION_REPORT_PATH, validation_report)

        stats = {
            "input_records": len(records),
            "output_records": len(transformed),
            "output_file": out_path,
        }
        save_metadata("completed", stats=stats)
        print(f"[AgentForge:{DOMAIN}] Done. Output: {OUTPUT_DIR}")

        if output_report["failed"] > 0:
            print(f"[!] {output_report['failed']} records failed output validation.")

    except Exception as exc:
        save_metadata("failed", error=str(exc))
        raise

if __name__ == "__main__":
    run()