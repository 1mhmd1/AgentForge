generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// USER
// ─────────────────────────────────────────
model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  role         Role      @default(USER)

  // Email/Password auth
  passwordHash String?   // null if user signed up with Google

  // Google OAuth
  googleId     String?   @unique // null if user signed up with email

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sessions     Session[]

  @@map("users")
}

// ─────────────────────────────────────────
// SESSION
// ─────────────────────────────────────────
model Session {
  id                String    @id @default(cuid())

  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // If session expired and user wants to continue →
  // a new session is created but linked to the previous one
  // so history carries over
  previousSessionId String?   @unique
  previousSession   Session?  @relation("SessionContinuation", fields: [previousSessionId], references: [id])
  continuedBy       Session?  @relation("SessionContinuation")

  expiresAt         DateTime
  lastSeenAt        DateTime  @default(now())
  createdAt         DateTime  @default(now())

  runs              Run[]

  @@map("sessions")
}

// ─────────────────────────────────────────
// RUN
// ─────────────────────────────────────────
model Run {
  id          String @id @default(cuid())

  // Add these two lines to link back to Session
  sessionId   String
  session     Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  userPrompt  String

  stage       Stage     @default(PLANNING)
  status      RunStatus @default(RUNNING)

  domain      Domain?

  spec        Json?

  finalError  String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agentRun    AgentRun?

  @@map("runs")
}

// ─────────────────────────────────────────
// AGENT RUN
// ─────────────────────────────────────────
model AgentRun {
  id      String @id @default(cuid())

  runId   String @unique
  run     Run    @relation(fields: [runId], references: [id], onDelete: Cascade)

  domain  Domain

  // ONLY execution result state
  status  AgentRunStatus @default(RUNNING)

  spec    Json?
  result  Json?

  semanticScore Float?
  isValid       Boolean?

  error         String?
  repairAttempts Int @default(0)

  logs     Json?
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([runId])
  @@map("agent_runs")
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────
enum Role {
  ADMIN
  USER
}

enum Domain {
  WEB_RESEARCH
  DOCUMENT
  DATA_TRANSFORM
  WEBSITE_BUILDER
}

enum Stage {
  PLANNING
  BUILDING
  VALIDATING
  COMPLETED
}

enum RunStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum AgentRunStatus {
  RUNNING
  COMPLETED
  FAILED
}