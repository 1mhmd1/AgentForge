generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// USER
// ─────────────────────────────────────────
model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  role         Role      @default(USER)
  status       UserStatus @default(ACTIVE)

  // Email/Password auth
  passwordHash String?   // null if user signed up with Google

  // Google OAuth
  googleId     String?   @unique // null if user signed up with email

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sessions     Session[]
  subscriptions Subscription[]

  @@map("users")
}

// ─────────────────────────────────────────
// SESSION
// ─────────────────────────────────────────
model Session {
  id                String    @id @default(cuid())

  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // If session expired and user wants to continue →
  // a new session is created but linked to the previous one
  // so history carries over
  previousSessionId String?   @unique
  previousSession   Session?  @relation("SessionContinuation", fields: [previousSessionId], references: [id])
  continuedBy       Session?  @relation("SessionContinuation")

  expiresAt         DateTime
  lastSeenAt        DateTime  @default(now())
  createdAt         DateTime  @default(now())

  runs              Run[]

  @@map("sessions")
}

// ─────────────────────────────────────────
// RUN
// ─────────────────────────────────────────
model Run {
  id          String @id @default(cuid())

  // Add these two lines to link back to Session
  sessionId   String
  session     Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  userPrompt  String

  stage       Stage     @default(PLANNING)
  status      RunStatus @default(RUNNING)

  domain      Domain?

  spec        Json?

  finalError  String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agentRun    AgentRun?

  @@map("runs")
}

// ─────────────────────────────────────────
// AGENT RUN
// ─────────────────────────────────────────
model AgentRun {
  id      String @id @default(cuid())

  runId   String @unique
  run     Run    @relation(fields: [runId], references: [id], onDelete: Cascade)

  domain  Domain

  // ONLY execution result state
  status  AgentRunStatus @default(RUNNING)

  spec    Json?
  result  Json?

  semanticScore Float?
  isValid       Boolean?

  error         String?
  repairAttempts Int @default(0)

  logs     Json?
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([runId])
  @@map("agent_runs")
}

// ─────────────────────────────────────────
// PLAN
// ─────────────────────────────────────────
model Plan {
  id          String           @id @default(cuid())
  name        String
  slug        String           @unique
  description String?
  price       Float
  currency    String           @default("USD")
  interval    PlanInterval     @default(MONTHLY)
  features    Json
  maxRuns     Int              @default(100)
  maxAgents   Int              @default(5)
  active      Boolean          @default(true)
  deletedAt   DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  subscriptions Subscription[]

  @@map("plans")
}

// ─────────────────────────────────────────
// SUBSCRIPTION
// ─────────────────────────────────────────
model Subscription {
  id         String             @id @default(cuid())
  userId     String
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId     String
  plan       Plan               @relation(fields: [planId], references: [id], onDelete: Restrict)
  status     SubscriptionStatus @default(PENDING)
  startedAt  DateTime           @default(now())
  expiresAt  DateTime
  canceledAt DateTime?

  @@index([userId])
  @@index([planId])
  @@map("subscriptions")
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────
enum Role {
  ADMIN
  USER
}

enum Domain {
  WEB_RESEARCH
  DOCUMENT
  DATA_TRANSFORM
  WEBSITE_BUILDER
}

enum Stage {
  PLANNING
  BUILDING
  VALIDATING
  COMPLETED
}

enum RunStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum AgentRunStatus {
  RUNNING
  COMPLETED
  FAILED
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  EXPIRED
  PENDING
}

enum PlanInterval {
  MONTHLY
  YEARLY
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DISABLED
}