# Frontend env — copy to apps/frontend/.env.local before `pnpm dev`.
#
# Vite only exposes vars prefixed with VITE_* to client code.

# Base URL the SPA hits. Points at the NestJS backend's global /api prefix.
# Default development: backend listens on PORT=3000.
VITE_API_BASE_URL=http://localhost:3000/api
