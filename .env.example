# ─────────────────────────────────────────────
# AgentForge — environment variables
# Copy to .env and fill in. Backend refuses to boot if any required
# variable below is missing or fails its zod validation.
# ─────────────────────────────────────────────

# ─── Core ─────────────────────────────────────
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ─── Database (REQUIRED) ──────────────────────
DATABASE_URL=postgresql://agentforge:agentforge@localhost:5432/agentforge?schema=public

# ─── Auth (REQUIRED) ──────────────────────────
# Use 32+ random bytes in production.
JWT_SECRET=replace-with-32-byte-random-string
JWT_REFRESH_SECRET=replace-with-different-32-byte-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Bootstrap admin: when set, the user registering with this email is
# auto-promoted to SUPER_ADMIN on signup. Leave blank in production unless
# you're seeding the first admin. After the first admin exists, manage roles
# via the admin console (/admin → Members → role dropdown).
ADMIN_EMAIL=

# Optional: Google OAuth (omit to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# ─── AI service (REQUIRED) ────────────────────
AI_SERVICE_URL=http://localhost:4000
AI_SERVICE_TIMEOUT_MS=120000
AI_PORT=4000

# LLM provider config (read by the AI service, not the backend)
LLM_PROVIDER=groq
GROQ_API_KEY=your_key_here
GEMINI_API_KEY=
MINIMAX_API_KEY=
KIMI_API_KEY=
MISTRAL_API_KEY=
# Optional Mistral model override (default: mistral-small-latest)
MISTRAL_MODEL=
OPENAI_API_KEY=
SANDBOX_TIMEOUT_MS=15000

# MCP doc tools (Microsoft Learn + Context7 + Exa). Off by default.
#
# When 1, the builder fetches reference docs once before sub-agent step_1
# and injects them into the prompt as authoritative API/library facts.
# Both endpoints are authless (no API key required).
#
# - Microsoft Learn (https://learn.microsoft.com/api/mcp): always queried with the goal text
# - Context7 (https://mcp.context7.com/mcp): only fires when the goal mentions a known
#   library/framework keyword (react, vue, pandas, etc.); 2-step resolve -> docs lookup
# - Exa (https://mcp.exa.ai/mcp): only fires for domain=web_research, AND only when
#   EXA_API_KEY is set below. Sign up free at https://exa.ai -> Dashboard -> API Keys.
#
# A 5-minute in-process TTL cache keyed on (domain, goal) avoids repeated
# fetches in dev. Cleared on process restart.
#
# Cost when enabled: roughly 5-20s extra per uncached build, plus ~500-1500
# tokens injected into step_1's prompt. Cache hits are sub-second.
AGENTFORGE_MCP_DOCS=0

# Exa API key for the web_research domain MCP. Free tier at https://exa.ai.
# Leave blank to skip Exa (Microsoft Learn + Context7 still work).
EXA_API_KEY=

# Qdrant vector database (template + run learning store). Both keys may be
# empty -- when QDRANT_URL is unset, the builder skips template retrieval
# and the validator skips persistence. The pipeline always degrades gracefully.
#
# Local docker: `docker run -p 6333:6333 qdrant/qdrant`  -> http://localhost:6333
# Qdrant Cloud: paste the cluster URL + API key from the dashboard.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your_qdrant_api_key_here

# ─── Redis (OPTIONAL infrastructure) ──────────
# When USE_REDIS=false (default), backend uses an in-memory fallback for the
# RedisService abstraction. The core AI pipeline NEVER depends on Redis - it's
# only a future plug-point for distributed rate limiting / concurrency counters
# / pub-sub. Setting USE_REDIS=true requires:
#   1. A reachable REDIS_URL
#   2. `ioredis` installed in apps/backend (pnpm add ioredis) — optional.
# If either is missing the backend logs a warning and stays on in-memory.
USE_REDIS=false
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ─── Storage / files ──────────────────────────
STORAGE_ROOT=./storage
MAX_UPLOAD_BYTES=5242880

# ─── LLM pricing (per 1k tokens, USD) ─────────
# CreditEntry rows are computed from `run_audit.total_tokens` × these.
LLM_PRICE_INPUT_PER_1K=0.5
LLM_PRICE_OUTPUT_PER_1K=1.5

# ─── Stripe (placeholder, billing module returns 501 until wired) ──
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Rate limiting ────────────────────────────
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=120

# ─── Logging ──────────────────────────────────
LOG_LEVEL=info

# ─── Frontend (Vite reads VITE_* at build time) ──
# API base URL the frontend hits. Should point at the NestJS backend's /api
# prefix. Backend listens on PORT (default 3000) and prefixes /api globally.
VITE_API_BASE_URL=http://localhost:3000/api
