# ─────────────────────────────────────────────
# AgentForge — environment variables
# Copy to .env and fill in. Backend refuses to boot if any required
# variable below is missing or fails its zod validation.
# ─────────────────────────────────────────────

# ─── Core ─────────────────────────────────────
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ─── Database (REQUIRED) ──────────────────────
DATABASE_URL=postgresql://agentforge:agentforge@localhost:5432/agentforge?schema=public

# ─── Auth (REQUIRED) ──────────────────────────
# Use 32+ random bytes in production.
JWT_SECRET=replace-with-32-byte-random-string
JWT_REFRESH_SECRET=replace-with-different-32-byte-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Optional: Google OAuth (omit to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# ─── AI service (REQUIRED) ────────────────────
AI_SERVICE_URL=http://localhost:4000
AI_SERVICE_TIMEOUT_MS=120000
AI_PORT=4000

# LLM provider config (read by the AI service, not the backend)
LLM_PROVIDER=groq
GROQ_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
SANDBOX_TIMEOUT_MS=15000

# ─── Redis (optional — falls back to DB-counted concurrency) ──
REDIS_URL=redis://localhost:6379

# ─── Qdrant (optional — Memory module falls back to SQL LIKE) ──
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ─── Storage / files ──────────────────────────
STORAGE_ROOT=./storage
MAX_UPLOAD_BYTES=5242880

# ─── LLM pricing (per 1k tokens, USD) ─────────
# CreditEntry rows are computed from `run_audit.total_tokens` × these.
LLM_PRICE_INPUT_PER_1K=0.5
LLM_PRICE_OUTPUT_PER_1K=1.5

# ─── Stripe (placeholder, billing module returns 501 until wired) ──
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Rate limiting ────────────────────────────
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=120

# ─── Logging ──────────────────────────────────
LOG_LEVEL=info

# ─── Frontend ─────────────────────────────────
VITE_API_URL=http://localhost:3000/api
