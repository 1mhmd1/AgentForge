# Workspace stub for `packages/shared` — referenced by apps/backend/package.json
# but no real shared package exists yet. The stub (package.json + index.{js,d.ts})
# lives locally so npm install resolves the workspace; do not commit it.
packages/shared/

# Test artifacts + temp
/tmp/_agf_*
scripts/_smoke_*.json
*.smoke.log

# One-shot probe scripts (per memory rule 17.13 — must be deleted before
# wrapping up, but ignore them so accidental check-ins don't happen).
/_probe*.py
/_trace*.py
/_smoke*.py
/_check*.py

